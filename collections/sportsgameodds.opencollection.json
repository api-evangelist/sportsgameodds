                "description": "Filter by sport"
              }
            ]
          },
          "docs": "Retrieve all supported leagues with optional sport filter."
        }
      ]
    },
    {
      "info": {
        "name": "Stats",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "List Stats",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.sportsgameodds.com/v1/stats/",
            "params": [
              {
                "name": "eventId",
